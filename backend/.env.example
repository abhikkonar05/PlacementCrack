MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/placementcrack?retryWrites=true&w=majority
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEVELOPER_MODE=false

# Optional AI provider. If empty, local rule-based evaluators are used.
GEMINI_API_KEY=
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_MODEL_ID=HuggingFaceH4/zephyr-7b-beta
HUGGINGFACE_ASR_MODEL_ID=openai/whisper-large-v3-turbo

# Optional OTP email provider. If empty and DEVELOPER_MODE=true, OTP is returned in API response.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@placementcrack.com
